---
export const prerender = false;

import BackLink from '../../components/BackLink.astro';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import NotionBlocks from '../../components/NotionBlocks.astro';
import Text from '../../components/Text.astro';
import { getBlogPostBySlug } from '../../lib/notion';

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam)
	? slugParam.join('/')
	: (slugParam ?? '');

const post = slug ? await getBlogPostBySlug(slug) : null;
if (!post) {
	return Astro.redirect('/blog');
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={post.title}
			description={post.excerpt ?? post.title}
		/>
	</head>
	<body class="min-h-screen bg-body text-primary">
		<main class="mx-auto max-w-3xl px-6 py-16 md:px-12 md:py-24">
			<BackLink />

			<article class="mt-8">
				<Text variant="headline1" as="h1" class="text-primary">
					{post.title}
				</Text>
				{post.pubDate && (
					<Text variant="body2" as="p" class="mt-3 text-tertiary">
						<FormattedDate date={post.pubDate} />
					</Text>
				)}
				<div class="notion-blocks mt-10">
					<NotionBlocks blocks={post.blocks} />
				</div>
			</article>
		</main>
	</body>
</html>
