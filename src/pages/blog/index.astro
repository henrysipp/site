---
export const prerender = false;

import NestedSectionLayout from '../../layouts/NestedSectionLayout.astro';
import { getBlogPosts } from '../../lib/notion';

const posts = await getBlogPosts();
const items = posts.map((post) => ({
	href: `/blog/${post.slug}`,
	label: post.title,
	date: post.pubDate?.toISOString(),
}));
---

<NestedSectionLayout
	title="Blog"
	description="Writing and notes"
	sectionLabel="Blog"
	items={items}
/>
