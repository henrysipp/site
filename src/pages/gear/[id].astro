---
export const prerender = false;

import NestedSectionLayout from '../../layouts/NestedSectionLayout.astro';
import Text from '../../components/Text.astro';
import PageDetails from '../../components/PageDetails.astro';
import NotionBlocks from '../../components/NotionBlocks.astro';
import { getGearItemBySlug, getGearItems } from '../../lib/notion';

const slug = Astro.params.id ?? '';
const item = slug ? await getGearItemBySlug(slug) : null;
if (!item) {
	return Astro.redirect('/gear');
}

const gear = await getGearItems();
const items = gear.map((entry) => ({
	href: `/gear/${entry.slug}`,
	label: entry.title,
}));
---

<NestedSectionLayout
	title={item.title}
	description={item.description ?? item.title}
	sectionLabel="Gear"
	items={items}
>
	<article>
		<Text variant="headline1" as="h1" class="text-primary">
			{item.title}
		</Text>
		<PageDetails
			usingSince={item.usingSince}
			lastEdited={item.lastEdited}
			tags={item.tags}
			type={item.type}
			link={item.link}
		/>
		{item.imageUrl && (
			<img
				src={item.imageUrl}
				alt=""
				class="mt-2 mb-6 w-full max-w-md rounded-lg"
			/>
		)}
		{item.description && (
			<Text variant="body1" class="text-secondary mb-6">
				{item.description}
			</Text>
		)}
		<div class="notion-blocks">
			<NotionBlocks blocks={item.blocks} />
		</div>
	</article>
</NestedSectionLayout>
