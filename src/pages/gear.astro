---
export const prerender = false;

import NestedSectionLayout from '../layouts/NestedSectionLayout.astro';
import { getGearItems } from '../lib/notion';

const gear = await getGearItems();
const items = gear.map((item) => ({
	href: `/gear/${item.slug}`,
	label: item.title,
}));
---

<NestedSectionLayout
	title="Gear"
	description="Things I use and like"
	sectionLabel="Gear"
	items={items}
/>
