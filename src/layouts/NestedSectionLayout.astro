---
import SidebarLayout from './SidebarLayout.astro';
import RouteLink from '../components/RouteLink.astro';
import Text from '../components/Text.astro';
import FormattedDate from '../components/FormattedDate.astro';

export interface NestedItem {
	href: string;
	label: string;
	date?: string;
}

interface Props {
	title: string;
	description: string;
	items: NestedItem[];
	sectionLabel: string;
}

const { title, description, items, sectionLabel } = Astro.props;
---

<SidebarLayout title={title} description={description}>
	<nav slot="list" class="flex flex-col space-y-7" aria-label={`${sectionLabel} routes`}>
		<Text variant="headline1" as="h2" class="text-primary mb-4">{sectionLabel}</Text>
		{items.map((item) => (
			<div class="flex flex-col gap-1.5">
				<RouteLink href={item.href}>{item.label}</RouteLink>
				{item.date && (
					<Text variant="body2" as="span" class="text-tertiary">
						<FormattedDate date={new Date(item.date)} />
					</Text>
				)}
			</div>
		))}
	</nav>

	<slot />
</SidebarLayout>
