---
import { fade } from 'astro:transitions';
---

<div
	transition:name="page-main"
	transition:animate={fade({ duration: '280ms' })}
	class="flex min-h-screen min-w-0 flex-col px-6 pt-8"
>
	<main
		class="flex-1 min-w-0"
		transition:animate={fade({ duration: '220ms' })}
		data-primary-content
	>
		<slot />
	</main>
</div>

<script>
	function revealPrimaryContent() {
		const content = document.querySelector<HTMLElement>('[data-primary-content]');
		const hasContent = Boolean(content?.children.length || content?.textContent?.trim());
		const isDesktop = window.matchMedia('(min-width: 768px)').matches;
		if (!hasContent || !isDesktop) return;

		const rightEdge = document.documentElement.scrollWidth - window.innerWidth;
		window.scrollTo({ left: rightEdge, behavior: 'instant' });
	}

	revealPrimaryContent();
	document.addEventListener('astro:after-swap', revealPrimaryContent);
</script>
