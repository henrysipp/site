---
interface Props {
  class?: string;
  id?: string;
}

const { class: className, id } = Astro.props;
---

<div class:list={['relative -mx-6 md:-mx-12', className]} data-horizontal-scroller data-scroller-id={id}>
	<div class="overflow-x-auto scrollbar-hide" data-scroller-inner data-lenis-prevent>
		<div class="flex w-max min-w-full gap-8 px-6 md:px-12" data-scroller-content>
			<slot />
		</div>
	</div>
</div>

<script>
	import Lenis from 'lenis';

	let scrollerInstances: Lenis[] = [];

	function initScrollers() {
		scrollerInstances.forEach((instance) => instance.destroy());
		scrollerInstances = [];

		document.querySelectorAll<HTMLElement>('[data-horizontal-scroller]').forEach((container) => {
			const wrapper = container.querySelector<HTMLElement>('[data-scroller-inner]');
			const content = container.querySelector<HTMLElement>('[data-scroller-content]');
			if (!wrapper || !content) return;

			const lenis = new Lenis({
				wrapper,
				content,
				autoRaf: true,
				duration: 0.8,
				easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
				orientation: 'horizontal',
				gestureOrientation: 'both',
				smoothWheel: true,
			});
			scrollerInstances.push(lenis);

			const scrollerId = container.dataset.scrollerId;
			const leftButton = scrollerId
				? document.querySelector<HTMLButtonElement>(`[data-scroll-left-for="${scrollerId}"]`)
				: null;
			const rightButton = scrollerId
				? document.querySelector<HTMLButtonElement>(`[data-scroll-right-for="${scrollerId}"]`)
				: null;

			function updateButtons() {
				if (leftButton) leftButton.disabled = lenis.scroll <= 0;
				if (rightButton) rightButton.disabled = lenis.scroll >= lenis.limit - 1;
			}

			leftButton?.addEventListener('click', () => {
				lenis.scrollTo(Math.max(0, lenis.scroll - 400));
			});
			rightButton?.addEventListener('click', () => {
				lenis.scrollTo(Math.min(lenis.limit, lenis.scroll + 400));
			});

			lenis.on('scroll', updateButtons);
			updateButtons();
		});
	}

	initScrollers();
	document.addEventListener('astro:page-load', initScrollers);
</script>
