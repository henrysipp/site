---
import FormattedDate from './FormattedDate.astro';
import Text from './Text.astro';

interface Props {
	pubDate?: Date;
	lastEdited?: Date;
	usingSince?: Date;
	tags?: string[];
	type?: string;
	link?: string;
}

const { pubDate, lastEdited, usingSince, tags = [], type, link } = Astro.props;

const rows: Array<{ label: string; kind: 'date' | 'text' | 'link'; value: Date | string }> =
	[];

if (pubDate) rows.push({ label: 'Published', kind: 'date', value: pubDate });
if (usingSince) rows.push({ label: 'Using since', kind: 'date', value: usingSince });
if (type) rows.push({ label: 'Type', kind: 'text', value: type });
if (tags.length) rows.push({ label: 'Tags', kind: 'text', value: tags.join(', ') });
if (link) rows.push({ label: 'Link', kind: 'link', value: link });
if (
	lastEdited &&
	(!pubDate || lastEdited.toDateString() !== pubDate.toDateString())
) {
	rows.push({ label: 'Updated', kind: 'date', value: lastEdited });
}

const hasDetails = rows.length > 0;
---

{
	hasDetails && (
		<dl class="not-prose -mr-6 my-6 space-y-2 border-y border-neutral-200 py-4 pr-6 dark:border-neutral-700">
			{rows.map((row) => (
				<div class="flex gap-4 items-baseline">
					<Text
						variant="body2"
						as="dt"
						class="w-28 shrink-0 text-tertiary"
					>
						{row.label}
					</Text>
					<Text variant="body2" as="dd" class="text-secondary min-w-0">
						{row.kind === 'date' ? (
							<FormattedDate date={row.value as Date} />
						) : row.kind === 'link' ? (
							<a
								href={row.value as string}
								target="_blank"
								rel="noopener noreferrer"
								class="text-primary underline underline-offset-2 break-all"
							>
								{(row.value as string).replace(/^https?:\/\//, '')}
							</a>
						) : (
							row.value
						)}
					</Text>
				</div>
			))}
		</dl>
	)
}
