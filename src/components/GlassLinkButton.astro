---
interface Props {
	href: string;
	ariaLabel?: string;
	class?: string;
	iconClass?: string;
	target?: '_blank' | '_parent' | '_self' | '_top';
	rel?: string;
}

const {
	href,
	ariaLabel,
	class: className,
	iconClass,
	target,
	rel,
} = Astro.props;
const hasIcon = Astro.slots.has('icon');
const hasLabel = Astro.slots.has('default');
---

<a
	href={href}
	aria-label={ariaLabel}
	target={target}
	rel={rel}
	class:list={[
		'group/linkButton glass-bg glass-shadow relative inline-flex grow-0 items-center justify-center gap-0.5 overflow-hidden rounded-full bg-clip-padding p-1.5 text-sm text-neutral-900 opacity-100 transition-all duration-100 hover:bg-neutral-500/10 hover:opacity-100 active:scale-95 dark:text-white',
		className,
	]}
>
	{hasIcon && (
		<span
			class:list={[
				'opacity-75 group-hover/linkButton:opacity-100',
				iconClass ?? '[&>svg]:size-4',
			]}
		>
			<slot name="icon" />
		</span>
	)}
	{hasLabel && (
		<span class="hidden pr-1.5 text-sm font-medium tracking-wide sm:block">
			<slot />
		</span>
	)}
</a>
