---
interface Props {
	label?: string;
}

const { label } = Astro.props;
---

<aside
	class="w-full self-start border-r border-neutral-200 bg-body px-12 dark:border-neutral-700 md:sticky md:top-[var(--top-bar-height)] md:h-[calc(100vh-var(--top-bar-height))] md:overflow-y-auto"
	aria-label={label}
	data-secondary-nav
	data-lenis-prevent
>
	<div class="pb-8 pt-8" data-secondary-nav-content>
		<slot />
	</div>
</aside>

<script>
	import Lenis from 'lenis';

	let secondaryNavLenis: Lenis | undefined;

	function initSecondaryNav() {
		secondaryNavLenis?.destroy();

		const wrapper = document.querySelector<HTMLElement>('[data-secondary-nav]');
		const content = wrapper?.querySelector<HTMLElement>('[data-secondary-nav-content]');
		if (!wrapper || !content) return;

		secondaryNavLenis = new Lenis({
			wrapper,
			content,
			autoRaf: true,
			duration: 0.8,
			easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
			orientation: 'vertical',
			gestureOrientation: 'vertical',
			smoothWheel: true,
		});
	}

	initSecondaryNav();
	document.addEventListener('astro:page-load', initSecondaryNav);
</script>
