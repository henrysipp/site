---
import NavLink from './NavLink.astro';
import { primaryNav, type NavItem } from '../lib/nav';

interface Props {
	items?: NavItem[];
}

const items = Astro.props.items ?? primaryNav;
---

<aside
	class="sticky left-0 top-[var(--top-bar-height)] z-30 hidden min-h-[calc(100vh-var(--top-bar-height))] self-start border-r border-neutral-200 bg-canvas/80 px-6 backdrop-blur-md dark:border-neutral-700 md:flex md:flex-col md:justify-center"
	transition:name="primary-nav"
	transition:animate="none"
>
	<nav class="space-y-2 flex flex-col">
		<NavLink href="/">Home</NavLink>
		{items.map((item) => (
			<NavLink href={item.href}>{item.label}</NavLink>
		))}
	</nav>
</aside>
