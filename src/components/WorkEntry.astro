---
import Text from './Text.astro';

interface Props {
  company: string;
  title: string;
  href?: string;
  class?: string;
}

const { company, title, href, class: className } = Astro.props;
---

<div class:list={['flex shrink-0 items-center gap-4', className]}>
  <span class="flex h-8 items-center justify-start [&_svg]:h-full [&_svg]:w-auto">
    <slot />
  </span>
  <div class="flex flex-col whitespace-nowrap">
    {href ? (
      <a href={href} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
        <Text variant="body1Emphasized" as="span">{company}</Text>
      </a>
    ) : (
      <Text variant="body1Emphasized" as="span" class="text-primary">{company}</Text>
    )}
    <Text variant="body2" as="span" class="text-tertiary">{title}</Text>
  </div>
</div>
