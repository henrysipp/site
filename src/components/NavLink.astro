---
import Text from './Text.astro';

interface Props {
	href: string;
}

const { href } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const targetPath = href.replace(/\/$/, '') || '/';
const isActive =
	targetPath === '/'
		? currentPath === '/'
		: currentPath === targetPath || currentPath.startsWith(`${targetPath}/`);
---

<a
	href={href}
	class:list={[
		'block transition-colors',
		isActive
			? 'text-primary'
			: 'text-tertiary hover:text-neutral-900 dark:hover:text-white',
	]}
>
	<Text variant={isActive ? 'body1Emphasized' : 'body1'} as="span">
		<slot />
	</Text>
</a>
